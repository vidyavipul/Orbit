<% page_title "Dashboard — Orbit" %>

<div class="content-header">
    <div>
        <h1 class="page-title">Good morning, <%= current_user.username.capitalize %>.</h1>
        <p class="page-subtitle">Here is what's happening with your team today.</p>
    </div>
    <div>
        <% if current_user.admin? || current_user.manager? %>
            <%= link_to "+ New Project", new_project_path, class: "btn btn-primary" %>
        <% end %>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <h3>Total Users</h3>
        <div class="value"><%= @total_users %></div>
    </div>
    <div class="stat-card">
        <h3>Active Projects</h3>
        <div class="value"><%= @active_projects %></div>
    </div>
    <div class="stat-card">
        <h3>Open Tasks</h3>
        <div class="value"><%= @open_tasks %></div>
    </div>
    <div class="stat-card">
        <h3>Overdue Tasks</h3>
        <div class="value alert"><%= @overdue_tasks %></div>
    </div>
</div>

<div class="dashboard-row">
    <!-- Recent Projects -->
    <div class="panel">
        <div class="panel-title">Recent Projects</div>
        <div class="table-container" style="border: none; margin-bottom: 0;">
            <% if @recent_projects.any? %>
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Project Name</th>
                            <th>Status</th>
                            <th>Deadline</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% @recent_projects.each do |project| %>
                            <tr style="cursor: pointer;" onclick="window.location='<%= project_path(project) %>'">
                                <td><strong><%= project.title %></strong></td>
                                <td><%= project_status_badge(project) %></td>
                                <td><%= format_date(project.deadline) %></td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            <% else %>
                <p style="color: var(--color-muted); font-size: 14px; padding: 10px;">No projects created yet.</p>
            <% end %>
        </div>
    </div>

    <!-- My Tasks -->
    <div class="panel">
        <div class="panel-title">My Tasks</div>
        <% if @my_tasks.any? %>
            <ul class="checklist">
                <% @my_tasks.each do |task| %>
                    <li class="checklist-item">
                        <input type="checkbox" id="chk-<%= task.id %>" disabled>
                        <div>
                            <%= link_to task.title, task_path(task), style: "font-weight: 500; color: inherit; text-decoration: none;" %>
                            <div class="task-meta"><%= task.project.title %> • <%= task.priority.titleize %> Priority</div>
                        </div>
                    </li>
                <% end %>
            </ul>
        <% else %>
            <p style="color: var(--color-muted); font-size: 14px;">You have no assigned tasks.</p>
        <% end %>
    </div>
</div>
