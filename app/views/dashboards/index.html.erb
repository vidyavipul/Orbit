<% content_for(:title, "Dashboard — Orbit") %>

<div class="content-header">
    <div>
        <h1 class="page-title">Good morning, <%= current_user.username.capitalize %>.</h1>
        <p class="page-subtitle">Here is what's happening with your team today.</p>
    </div>
    <div>
        <% if current_user.admin? || current_user.manager? %>
            <%= link_to "+ New Project", new_project_path, class: "btn btn-primary" %>
        <% end %>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <h3>Total Users</h3>
        <div class="value"><%= @total_users %></div>
    </div>
    <div class="stat-card">
        <h3>Active Projects</h3>
        <div class="value"><%= @active_projects %></div>
    </div>
    <div class="stat-card">
        <h3>Open Tasks</h3>
        <div class="value"><%= @open_tasks %></div>
    </div>
    <div class="stat-card">
        <h3>Overdue Tasks</h3>
        <div class="value alert"><%= @overdue_tasks %></div>
    </div>
</div>

<div class="dashboard-row">
    <!-- Recent Projects -->
    <div class="panel">
        <div class="panel-title">Recent Projects</div>
        <div class="table-container" style="border: none; margin-bottom: 0;">
            <% if @recent_projects.any? %>
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Project Name</th>
                            <th>Status</th>
                            <th>Deadline</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% @recent_projects.each do |project| %>
                            <tr>
                                <td><strong><%= link_to project.title, project_path(project), style: "color: inherit; text-decoration: none;" %></strong></td>
                                <td>
                                    <% if project.active? %>
                                        <span class="badge badge-success">Active</span>
                                    <% else %>
                                        <span class="badge badge-secondary"><%= project.status.titleize %></span>
                                    <% end %>
                                </td>
                                <td><%= format_date(project.deadline) %></td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            <% else %>
                <p style="color: var(--color-muted); font-size: 14px; padding: 10px;">No projects created yet.</p>
            <% end %>
        </div>
    </div>

    <!-- My Tasks -->
    <div class="panel">
        <div class="panel-title">My Tasks</div>
        <% if @my_tasks.any? %>
            <ul class="checklist">
                <% @my_tasks.each do |task| %>
                    <li class="checklist-item">
                        <input type="checkbox" id="chk-<%= task.id %>" onclick="window.location='<%= task_path(task) %>'">
                        <div>
                            <label for="chk-<%= task.id %>" style="font-weight: 500; cursor: pointer;" onclick="window.location='<%= task_path(task) %>'"><%= task.title %></label>
                            <div class="task-meta"><%= task.project.title %> • <%= priority_badge(task.priority) %> Priority</div>
                        </div>
                    </li>
                <% end %>
            </ul>
        <% else %>
            <p style="color: var(--color-muted); font-size: 14px;">You have no assigned tasks.</p>
        <% end %>
    </div>
</div>
