<aside class="sidebar">
  <div class="logo-container">
    <div class="logo-icon"></div>
    <%= link_to "Orbit", dashboard_path, style: "color: inherit; text-decoration: none;" %>
  </div>
  <ul class="nav-links">
    <li>
      <%= link_to dashboard_path, class: "nav-item #{current_page?(dashboard_path) ? 'active' : ''}" do %>
        📊 Dashboard
      <% end %>
    </li>
    <li>
      <%= link_to projects_path, class: "nav-item #{current_page?(projects_path) || request.path.start_with?('/projects') ? 'active' : ''}" do %>
        📁 Projects
      <% end %>
    </li>
    <li>
      <div class="nav-item">✓ Tasks</div>
    </li>
    <li>
      <%= link_to users_path, class: "nav-item #{current_page?(users_path) || request.path.start_with?('/users') ? 'active' : ''}" do %>
        👥 Team
      <% end %>
    </li>
  </ul>
  
  <%= link_to edit_user_path(current_user), class: "sidebar-user", style: "text-decoration: none; color: inherit; cursor: pointer;" do %>
    <div class="user-avatar"><%= user_initials(current_user) %></div>
    <div class="user-info">
      <h4><%= current_user.full_name %></h4>
      <p><%= current_user.role.capitalize %></p>
    </div>
  <% end %>
  
  <div style="margin-top: 20px; text-align: center;">
    <%= link_to "Log out", logout_path, data: { turbo_method: :delete }, class: "btn btn-outline", style: "width: 100%; border-radius: 6px;" %>
  </div>
</aside>
