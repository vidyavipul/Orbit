<% content_for(:title, "Edit Project — Orbit") %>

<div class="content-header">
  <div>
    <h1 class="page-title">Edit Project</h1>
    <p class="page-subtitle">Update project details and status.</p>
  </div>
</div>

<div class="panel" style="max-width: 600px;">
  <% content_for :submit_label, "Update Project" %>
  <%= render 'form', project: @project %>
</div>

<% if current_user && current_user.admin? %>
<div class="panel" style="max-width: 600px; margin-top: 24px; border-color: var(--color-cta);">
  <div class="panel-title" style="color: var(--color-cta);">Danger Zone</div>
  <p style="font-size: 14px; margin-bottom: 16px;">Once you delete a project, there is no going back. Please be certain.</p>
  <%= button_to "Delete Project", project_path(@project), method: :delete, class: "btn btn-cta", form: { data: { turbo_confirm: "Are you sure you want to delete this project?" } } %>
</div>
<% end %>
