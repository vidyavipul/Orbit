<% page_title "#{@project.title} — Orbit" %>

<div class="breadcrumb">
  <%= link_to "Projects", projects_path %> &gt;
  <span><%= @project.title %></span>
</div>

<div class="content-header">
  <div>
    <h1 class="page-title"><%= @project.title %></h1>
    <p class="page-subtitle"><%= @project.description %></p>
  </div>
  <div style="display: flex; gap: 8px;">
    <% if current_user.admin? || current_user.manager? %>
      <%= link_to "+ New Task", new_project_task_path(@project), class: "btn btn-primary" %>
      <%= link_to "Edit Project", edit_project_path(@project), class: "btn btn-outline" %>
    <% end %>
  </div>
</div>

<div class="stats-grid" style="grid-template-columns: repeat(3, 1fr); margin-bottom: 30px;">
  <div class="stat-card">
    <h3>Status</h3>
    <div style="margin-top: 4px;"><%= project_status_badge(@project) %></div>
  </div>
  <div class="stat-card">
    <h3>Deadline</h3>
    <div class="value" style="font-size: 20px;">
      <%= format_date(@project.deadline) %>
      <% if @project.overdue? %>
        <span style="color: var(--color-cta); font-size: 12px; margin-left: 4px;">(Overdue)</span>
      <% end %>
    </div>
  </div>
  <div class="stat-card">
    <h3>Total Tasks</h3>
    <div class="value"><%= @project.tasks.count %></div>
  </div>
</div>

<div class="table-container">
  <table class="custom-table">
    <thead>
      <tr>
        <th width="40"><input type="checkbox" disabled></th>
        <th>Task Title</th>
        <th>Priority</th>
        <th>Status</th>
        <th>Due Date</th>
        <th>Assignee</th>
        <th style="text-align: right;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @project.tasks.order(created_at: :desc).each do |task| %>
        <tr style="cursor: pointer;" onclick="if(event.target.tagName !== 'A' && event.target.tagName !== 'INPUT') window.location='<%= task_path(task) %>'">
          <td><input type="checkbox" <%= 'checked' if task.completed? %> disabled></td>
          <td style="<%= 'text-decoration: line-through; color: var(--color-muted);' if task.completed? %>">
            <strong><%= task.title %></strong>
          </td>
          <td><%= priority_badge(task.priority) %></td>
          <td><%= status_badge(task) %></td>
          <td><%= format_date(task.due_date) %></td>
          <td><%= task.user.full_name %></td>
          <td style="text-align: right;">
            <% if current_user.admin? || current_user.manager? || (current_user.employee? && task.user_id == current_user.id) %>
              <%= link_to "Edit", edit_task_path(task), class: "btn btn-outline btn-sm" %>
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @project.tasks.empty? %>
        <tr>
          <td colspan="7" style="text-align: center; padding: 2rem; color: var(--color-muted);">No tasks for this project yet.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
