<% page_title "Projects — Orbit" %>

<div class="content-header">
  <div>
    <h1 class="page-title">Projects</h1>
    <p class="page-subtitle">Track high-level goals and ongoing projects.</p>
  </div>
  <% if current_user.admin? || current_user.manager? %>
    <div>
      <%= link_to "+ New Project", new_project_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

<div class="filters-bar">
  <div class="filter-tabs">
    <%= link_to "All Projects", projects_path(sort: params[:sort]), class: "filter-tab #{'active' if params[:filter].blank?}" %>
    <%= link_to "Active", projects_path(filter: 'active', sort: params[:sort]), class: "filter-tab #{'active' if params[:filter] == 'active'}" %>
    <%= link_to "Completed", projects_path(filter: 'completed', sort: params[:sort]), class: "filter-tab #{'active' if params[:filter] == 'completed'}" %>
    <%= link_to "Overdue", projects_path(filter: 'overdue', sort: params[:sort]), class: "filter-tab #{'active' if params[:filter] == 'overdue'}" %>
  </div>
  
  <%= form_with url: projects_path, method: :get, local: true, style: "display: inline-block;" do |f| %>
    <%= f.hidden_field :filter, value: params[:filter] %>
    <%= f.hidden_field :sort, value: params[:sort] %>
    <%= f.text_field :search, value: params[:search], placeholder: "Search projects...", class: "search-input" %>
  <% end %>
</div>

<div class="table-container">
  <table class="custom-table">
    <thead>
      <tr>
        <th>Project Name</th>
        <th>Description</th>
        <th>Status</th>
        <th>Deadline</th>
        <th style="text-align: right;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @projects.each do |project| %>
        <tr>
          <td><strong><%= link_to project.title, project_path(project), style: "color: inherit; text-decoration: none;" %></strong></td>
          <td style="color: var(--color-muted);"><%= truncate_text(project.description, length: 50) %></td>
          <td><%= project_status_badge(project) %></td>
          <td><%= format_date(project.deadline) %></td>
          <td style="text-align: right; display: flex; justify-content: flex-end; gap: 8px;">
            <%= link_to "View Tasks", project_tasks_path(project), class: "btn btn-outline btn-sm" %>
            <% if current_user.admin? || current_user.manager? %>
              <%= link_to "Edit", edit_project_path(project), class: "btn btn-outline btn-sm" %>
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @projects.empty? %>
        <tr>
          <td colspan="5" style="text-align: center; color: var(--color-muted); padding: 20px;">No projects found matching your criteria.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="pagination">
  <div class="page-subtitle">
    <% if @projects.respond_to?(:total_entries) && @projects.any? %>
      Showing <%= @projects.length %> of <%= @projects.total_entries %> projects
    <% end %>
  </div>
  <% if @projects.respond_to?(:total_pages) && @projects.total_pages > 1 %>
    <%= will_paginate @projects, renderer: OrbitPaginationRenderer %>
  <% end %>
</div>
