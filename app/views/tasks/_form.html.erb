<%= form_with model: @task.persisted? ? @task : [ @project, @task ], local: true, class: "custom-form" do |f| %>
  <% if @task.errors.any? %>
    <div class="error-messages" style="color: var(--color-cta); margin-bottom: 1.5rem; background: rgba(181, 96, 74, 0.1); padding: 1rem; border-radius: 8px;">
      <h4 style="margin-bottom: 0.5rem; margin-top: 0;"><%= pluralize(@task.errors.count, "error") %> prohibited this task from being saved:</h4>
      <ul style="padding-left: 1.5rem; margin-bottom: 0;">
        <% @task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if current_user.admin? || current_user.manager? %>
      <div class="form-group" style="margin-bottom: 1.5rem;">
        <%= f.label :title, style: "display: block; font-weight: 500; margin-bottom: 0.5rem;" %>
        <%= f.text_field :title, class: "auth-form-control", style: "width: 100%;", required: true %>
      </div>

      <div class="form-group" style="margin-bottom: 1.5rem;">
        <%= f.label :description, style: "display: block; font-weight: 500; margin-bottom: 0.5rem;" %>
        <%= f.text_area :description, class: "auth-form-control", style: "width: 100%; min-height: 100px;", required: true %>
      </div>

      <div class="form-group" style="margin-bottom: 1.5rem;">
        <%= f.label :user_id, "Assign To", style: "display: block; font-weight: 500; margin-bottom: 0.5rem;" %>
        <%= f.collection_select :user_id, User.active, :id, :full_name, { prompt: "Select a user" }, class: "auth-form-control", style: "width: 100%;", required: true %>
      </div>

      <div class="form-group" style="margin-bottom: 1.5rem;">
        <%= f.label :due_date, style: "display: block; font-weight: 500; margin-bottom: 0.5rem;" %>
        <%= f.date_field :due_date, class: "auth-form-control", style: "width: 100%;", required: true %>
      </div>

      <div class="form-group" style="margin-bottom: 1.5rem;">
        <%= f.label :priority, style: "display: block; font-weight: 500; margin-bottom: 0.5rem;" %>
        <%= f.select :priority, Task.priorities.keys.map { |p| [p.titleize, p] }, {}, class: "auth-form-control", style: "width: 100%;" %>
      </div>
  <% else %>
      <%# Employees can't edit these fields, but it's good to show what they are editing the status for %>
      <div class="form-group" style="margin-bottom: 1.5rem;">
        <label style="display: block; font-weight: 500; margin-bottom: 0.5rem; color: var(--color-muted);">Task Title (Read Only)</label>
        <div style="padding: 10px 12px; background: var(--color-bg); border-radius: 8px; border: 1px solid var(--color-border);"><%= @task.title %></div>
      </div>
  <% end %>
  
  <div class="form-group" style="margin-bottom: 1.5rem;">
    <%= f.label :status, style: "display: block; font-weight: 500; margin-bottom: 0.5rem;" %>
    <%= f.select :status, Task.statuses.keys.map { |s| [s.titleize, s] }, {}, class: "auth-form-control", style: "width: 100%;" %>
  </div>

  <div class="form-actions" style="margin-top: 2rem;">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", @task.persisted? ? task_path(@task) : ( @project ? project_tasks_path(@project) : tasks_path ), class: "btn btn-outline", style: "margin-left: 10px;" %>
  </div>
<% end %>
