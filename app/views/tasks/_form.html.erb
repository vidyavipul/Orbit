<%= render 'shared/errors', obj: @task %>

<%= form_with model: @task, url: @task.persisted? ? task_path(@task) : project_tasks_path(@project), local: true do |f| %>

  <% if current_user.admin? || current_user.manager? %>
      <div class="auth-form-group">
        <%= f.label :title %>
        <%= f.text_field :title, class: "auth-form-control", placeholder: "Design new onboarding flow", required: true %>
      </div>

      <div class="auth-form-group">
        <%= f.label :description %>
        <%= f.text_area :description, class: "auth-form-control", placeholder: "Detailed description of the task...", rows: 4, required: true %>
      </div>

      <div class="auth-form-group">
        <%= f.label :user_id, "Assign To" %>
        <%= f.collection_select :user_id, User.active, :id, :full_name, { prompt: "Select a team member" }, class: "auth-form-control", required: true %>
      </div>

      <div class="auth-form-group">
        <%= f.label :due_date %>
        <%= f.date_field :due_date, class: "auth-form-control", required: true %>
      </div>

      <div class="auth-form-group">
        <%= f.label :priority %>
        <%= f.select :priority, Task.priorities.keys.map { |p| [p.titleize, p] }, {}, class: "auth-form-control" %>
      </div>
  <% else %>
      <div class="auth-form-group">
        <label style="color: var(--color-muted);">Task Title (Read Only)</label>
        <div style="padding: 12px 16px; background: var(--bg-light); border-radius: 8px; border: 1px solid var(--color-border);"><%= @task.title %></div>
      </div>
  <% end %>
  
  <div class="auth-form-group">
    <%= f.label :status %>
    <%= f.select :status, Task.statuses.keys.map { |s| [s.titleize, s] }, {}, class: "auth-form-control" %>
  </div>

  <div style="margin-top: 20px;">
    <%= f.submit @task.persisted? ? "Update Task" : "Create Task", class: "btn btn-primary" %>
    <% if @task.persisted? %>
      <%= link_to "Cancel", task_path(@task), class: "btn btn-outline", style: "margin-left: 10px;" %>
    <% elsif @project %>
      <%= link_to "Cancel", project_tasks_path(@project), class: "btn btn-outline", style: "margin-left: 10px;" %>
    <% else %>
      <%= link_to "Cancel", tasks_path, class: "btn btn-outline", style: "margin-left: 10px;" %>
    <% end %>
  </div>
<% end %>
