<% page_title "Edit Task" %>

<div class="breadcrumb">
    <%= link_to "Projects", projects_path %> &gt;
    <%= link_to @task.project.title, project_path(@task.project) %> &gt;
    <%= link_to "Tasks", project_tasks_path(@task.project) %> &gt;
    <%= link_to @task.title, task_path(@task) %> &gt;
    <span>Edit</span>
</div>

<div class="content-header">
  <h1 class="page-title">Edit Task</h1>
</div>

<div class="panel" style="max-width: 600px;">
  <div class="panel-title">Task Details</div>
  <%= render 'form' %>
</div>

<% if current_user.admin? %>
<div class="panel" style="max-width: 600px; margin-top: 24px; border-color: var(--color-cta);">
  <div class="panel-title" style="color: var(--color-cta);">Danger Zone</div>
  <p style="font-size: 14px; margin-bottom: 16px;">Once you delete a task, there is no going back. Please be certain.</p>
  <%= button_to "Delete Task", task_path(@task), method: :delete, class: "btn btn-cta", form: { data: { turbo_confirm: "Are you sure you want to delete this task?" } } %>
</div>
<% end %>
