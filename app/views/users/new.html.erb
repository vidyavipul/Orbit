<% content_for(:title, "Sign Up — Orbit") %>

<div class="home-view">
  <%= render 'shared/navbar' %>

  <section class="auth-page-section">
    <div class="auth-page-container">
      <div class="auth-page-left">
        <div class="hero-tag">Get Started Free</div>
        <h1 class="hero-title">Create your Orbit account.</h1>
        <p class="hero-subtitle">
          Join your team's workspace in seconds. Track projects, manage tasks, and stay focused — all in one calm, organized place.
        </p>
        <div class="hero-stats">
          <div class="hero-stat-item">
            <div class="hero-stat-dot"></div> No credit card
          </div>
          <div class="hero-stat-item">
            <div class="hero-stat-dot"></div> Free forever
          </div>
          <div class="hero-stat-item">
            <div class="hero-stat-dot"></div> Setup in 30s
          </div>
        </div>
      </div>

      <div class="auth-page-right">
        <div class="auth-card">
          <h2 class="auth-card-title">Sign Up</h2>

          <%= render 'shared/errors', obj: @user %>

          <%= form_with(model: @user, url: signup_path, local: true, id: "signup-form") do |f| %>
            <div class="auth-form-group">
              <label for="user_username">Username</label>
              <%= f.text_field :username, class: "auth-form-control", placeholder: "Username", required: true, id: "user_username", autofocus: true %>
            </div>

            <div class="auth-form-group">
              <label for="user_email">Email Address</label>
              <%= f.email_field :email, class: "auth-form-control", placeholder: "Email", required: true, id: "user_email" %>
            </div>

            <div class="auth-form-group">
              <label for="user_password">Password</label>
              <%= f.password_field :password, class: "auth-form-control", placeholder: "Password", required: true, id: "user_password" %>
            </div>

            <div class="auth-form-group">
              <label for="user_password_confirmation">Confirm Password</label>
              <%= f.password_field :password_confirmation, class: "auth-form-control", placeholder: "Password", required: true, id: "user_password_confirmation" %>
            </div>

            <%= f.submit "Create Account", class: "btn btn-cta auth-submit-btn", id: "signup-submit" %>
          <% end %>

          <div class="auth-divider">or</div>

          <%= link_to "Already have an account? Log in", login_path, class: "btn btn-outline auth-alt-btn", id: "goto-login" %>
        </div>
      </div>
    </div>
  </section>

  <%= render 'shared/footer' %>
</div>
