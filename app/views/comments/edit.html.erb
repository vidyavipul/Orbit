<% page_title "Edit Comment" %>

<div class="breadcrumb">
    <%= link_to "Projects", projects_path %> &gt;
    <%= link_to @comment.task.project.title, project_path(@comment.task.project) %> &gt;
    <%= link_to "Tasks", project_tasks_path(@comment.task.project) %> &gt;
    <%= link_to @comment.task.title, task_path(@comment.task) %> &gt;
    <span>Edit Comment</span>
</div>

<div class="content-header">
  <h1 class="page-title">Edit Comment</h1>
</div>

<div class="panel" style="max-width: 600px;">
  <div class="panel-title">Update Comment</div>
  
  <%= render 'shared/errors', obj: @comment %>

  <div class="comment-form" style="margin-top: 16px;">
    <%= form_with model: @comment, url: comment_path(@comment), local: true do |f| %>
      <%= f.text_area :body, required: true, style: "width: 100%; height: 100px; padding: 12px; border-radius: 8px; border: 1px solid var(--color-border); background-color: var(--bg-light); font-family: var(--font-ui); font-size: 14px; resize: vertical;" %>
      <div style="margin-top: 12px; display: flex; gap: 8px;">
        <%= f.submit "Update Comment", class: "btn btn-primary btn-sm" %>
        <%= link_to "Cancel", task_path(@comment.task), class: "btn btn-outline btn-sm" %>
      </div>
    <% end %>
  </div>
</div>
